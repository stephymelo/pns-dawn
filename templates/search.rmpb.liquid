{%- layout none -%}
{%- comment -%}
  Alternate search view used by the Rimix Product Badges app (`?view=rmpb`).
  Rimix fetches /search?q=handle:"x" OR handle:"y"...&view=rmpb to resolve each
  product's tags / inventory / sale state and decide which badge to show on
  product CARDS (collection & home grids). It expects a JSON array; if this view
  is missing the request falls back to Dawn's HTML search page and Rimix logs
  "RMPB: Unexpected token '<' ... is not valid JSON" and shows no card badges.
  Do not add layout/markup here — the response must be pure JSON.
{%- endcomment -%}
[
{%- for product in search.results -%}
  {%- assign p_cap = product.compare_at_price | default: product.price -%}
  {%- assign v = product.selected_or_first_available_variant -%}
  {%- assign v_cap = v.compare_at_price | default: v.price -%}
  {
        "id": {{ product.id }},
        "available": {{ product.available }},
        "title": {{ product.title | json }},
        "handle": {{ product.handle | json }},
        "url": "{{ product.url }}",
        "type": "{% if product.has_only_default_variant %}simple{% else %}variant{% endif %}",
        "price": {{ product.price }},
        "compare_at_price": {{ p_cap }},
        "created_at": "{{ product.created_at | date: '%s' }}000",
        "published_at": "{{ product.published_at | date: '%s' }}000",
        "tags": {{ product.tags | json }},
        "vendor": {{ product.vendor | json }},
        "featured_image": "{% if product.featured_image %}{{ product.featured_image | image_url: width: 500 }}{% endif %}",
        "images": [{%- for image in product.images -%}{"id": {{ image.id }}, "src": "{{ image | image_url: width: 500 }}"}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
        "collections": [{{ product.collections | map: 'id' | join: ',' }}],"variant": {
        "id": "{{ v.id }}",
        "title": {{ v.title | json }},
        "available": {{ v.available }},
        "featured_image": "{% if v.featured_image %}{{ v.featured_image | image_url: width: 500 }}{% endif %}",
        "inventory_management": "{{ v.inventory_management }}",
        "inventory_policy": "{{ v.inventory_policy }}",
        "inventory_quantity": {{ v.inventory_quantity | default: 0 }},
        "price": {{ v.price }},
        "compare_at_price": {{ v_cap }},
        "sale_amount": "{{ v_cap | minus: v.price | money }}",
        "sale_percent": {% if v_cap > 0 %}{{ v_cap | minus: v.price | times: 100 | divided_by: v_cap }}{% else %}0{% endif %},
        "on_sale":{% if v.compare_at_price > v.price %}true{% else %}false{% endif %}},

        "variants": {{% for var in product.variants %}{%- assign var_cap = var.compare_at_price | default: var.price -%}"{{ var.id }}": {
            "id": {{ var.id }},
            "title": {{ var.title | json }},
            "name": null,
            "price": {{ var.price }},
            "featured_image": "{% if var.featured_image %}{{ var.featured_image | image_url: width: 500 }}{% endif %}",
            "compare_at_price": {{ var_cap }},
            "sale_amount": "{{ var_cap | minus: var.price | money }}",
            "sale_percent": {% if var_cap > 0 %}{{ var_cap | minus: var.price | times: 100 | divided_by: var_cap }}{% else %}0{% endif %},
            "available": {{ var.available }},
            "inventory_management": "{{ var.inventory_management }}",
            "inventory_policy": "{{ var.inventory_policy }}",
            "inventory_quantity": {{ var.inventory_quantity | default: 0 }},
            "selected":{% if var.id == v.id %}true{% else %}false{% endif %},
            "on_sale":{% if var.compare_at_price > var.price %}true{% else %}false{% endif %}}{%- unless forloop.last -%},{%- endunless -%}{% endfor %}},

        "on_sale": {% if product.compare_at_price > product.price %}true{% else %}false{% endif %},
        "inventory": 999999
        }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
