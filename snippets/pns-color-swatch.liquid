{%- comment -%}
  Renders a nail-swatch image for a color value, pulled from the "Color Nail Swatch"
  metaobject (type handle: color_nail_swatch) and matched to the color name.
  Mirrors pns-brand-logo, which does the same for brand logos.

  Accepts:
  - color {String} — the color value/name to look up (the Color facet value label, e.g. "Black")

  How matching works (verified against the live metaobject):
  - Each metaobject entry's handle IS the color name, lowercased and hyphenated
    (e.g. "Black" -> "black", "Hot Pink" -> "hot-pink").
  - The nail-swatch picture lives on the entry's `image` field.
  - The entry's `fields` array is NOT iterable from the storefront here, so we match on
    the handle (with a text-field fallback) instead of scanning fields.

  Outputs the <img>, or nothing if there's no matching entry.
  Change color_mo_type in one place if the metaobject type handle ever moves.
{%- endcomment -%}
{%- liquid
  assign color_mo_type = 'color_nail_swatch'

  assign color_key = color | downcase | strip
  assign color_key_dash = color_key | replace: ' ', '-'
  assign swatch_img = null

  assign entries = shop.metaobjects[color_mo_type].values
  for entry in entries
    assign entry_handle = entry.system.handle | downcase | strip
    assign is_match = false

    # Primary: the entry handle equals the color name (Shopify hyphenates spaces)
    if entry_handle == color_key or entry_handle == color_key_dash
      assign is_match = true
    endif

    # Fallback: match any text field on the entry (in case handles ever differ)
    unless is_match
      for f in entry.fields
        if f.type contains 'text'
          assign fv = f.value | downcase | strip
          if fv == color_key
            assign is_match = true
          endif
        endif
      endfor
    endunless

    if is_match
      # Primary image field is `image`; fall back to any file/image field on the entry
      if entry.image != blank
        assign swatch_img = entry.image
      else
        for f in entry.fields
          if f.value.image != blank
            assign swatch_img = f.value.image
          elsif f.type contains 'file' and f.value != blank
            assign swatch_img = f.value
          elsif f.type contains 'image' and f.value != blank
            assign swatch_img = f.value
          endif
        endfor
      endif
      break
    endif
  endfor
-%}
{%- if swatch_img != blank -%}
  {{ swatch_img | image_url: width: 160 | image_tag: class: 'pns-color-swatch__img', alt: color, loading: 'lazy', widths: '80, 160' }}
{%- endif -%}
