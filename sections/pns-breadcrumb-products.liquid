{{ 'pns-breadcrumb-products.css' | asset_url | stylesheet_tag }}

<nav class="pns-breadcrumb" style="--pns-bc-bg: {{ section.settings.background_color }}; --pns-bc-text: {{ section.settings.text_color }};" aria-label="Breadcrumb">
  <div class="page-width pns-breadcrumb__inner">
    <a href="{{ routes.root_url }}" class="pns-breadcrumb__item pns-breadcrumb__home">
      <svg class="pns-breadcrumb__home-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3l9 8h-3v9h-4v-6h-4v6H6v-9H3l9-8z"/></svg>
      <span>Home</span>
    </a>
    {%- if product -%}
      {%- comment -%}
        `collection` is only set when the product is reached via /collections/x/products/y.
        Through a direct product link there is no collection context, so fall back to the
        product's first real collection (skipping the generic frontpage/all collections).
      {%- endcomment -%}
      {%- liquid
        assign bc_collection = collection
        if bc_collection == blank or bc_collection.handle == blank
          for c in product.collections
            unless c.handle == 'frontpage' or c.handle == 'all'
              assign bc_collection = c
              break
            endunless
          endfor
        endif
      -%}
      <span class="pns-breadcrumb__sep" aria-hidden="true">›</span>
      {%- if bc_collection and bc_collection.handle -%}
        <a href="{{ bc_collection.url }}" class="pns-breadcrumb__item">{{ bc_collection.title | escape }}</a>
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}" class="pns-breadcrumb__item">{{ section.settings.fallback_label | default: 'All' | escape }}</a>
      {%- endif -%}
      <span class="pns-breadcrumb__sep" aria-hidden="true">›</span>
      <span class="pns-breadcrumb__item pns-breadcrumb__current" aria-current="page">{{ product.title | escape }}</span>
    {%- endif -%}
  </div>
</nav>

{% schema %}
{
  "name": "PNS Breadcrumb Products",
  "tag": "section",
  "class": "pns-breadcrumb-products-section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "fallback_label",
      "label": "Fallback middle crumb (when no collection)",
      "default": "All"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  },
  "presets": [
    {
      "name": "PNS Breadcrumb Products"
    }
  ]
}
{% endschema %}
