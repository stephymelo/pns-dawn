{{ 'pns-custom.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pns-home-banner.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign slide_count = 0
  for block in section.blocks
    if block.type == 'slide'
      assign slide_count = slide_count | plus: 1
    endif
  endfor
-%}

<div class="pns-home-banner color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="pns-home-banner__grid">
      {%- comment -%} Left: rotating banner {%- endcomment -%}
      <pns-home-banner
        class="pns-home-banner__slider"
        data-interval="{{ section.settings.rotate_speed | times: 1000 }}"
      >
        <div class="pns-home-banner__stage">
          {%- if slide_count > 1 -%}
            <button class="slider-button slider-button--prev" data-pns-banner-prev aria-label="{{ 'general.slider.previous_slide' | t }}">
              <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
            </button>
          {%- endif -%}
          <div class="pns-home-banner__viewport">
            <div class="pns-home-banner__track" data-pns-banner-track>
              {%- for block in section.blocks -%}
                {%- if block.type == 'slide' -%}
                  <div class="pns-home-banner__slide" {{ block.shopify_attributes }}>
                    {%- if block.settings.link != blank -%}
                      <a href="{{ block.settings.link }}" class="pns-home-banner__slide-link">
                    {%- endif -%}
                    {%- if block.settings.image != blank -%}
                      {{
                        block.settings.image
                        | image_url: width: 1400
                        | image_tag:
                          loading: 'lazy',
                          widths: '375, 550, 750, 1100, 1400',
                          sizes: '(min-width: 990px) 60vw, 100vw',
                          class: 'pns-home-banner__image'
                      }}
                    {%- else -%}
                      {{ 'hero-apparel-1' | placeholder_svg_tag: 'pns-home-banner__image placeholder' }}
                    {%- endif -%}
                    {%- if block.settings.link != blank -%}
                      </a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
          {%- if slide_count > 1 -%}
            <button class="slider-button slider-button--next" data-pns-banner-next aria-label="{{ 'general.slider.next_slide' | t }}">
              <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
            </button>
          {%- endif -%}
        </div>

        {%- if slide_count > 1 -%}
          <div class="pns-home-banner__dots">
            {%- for i in (1..slide_count) -%}
              <button
                class="pns-home-banner__dot{% if forloop.first %} is-active{% endif %}"
                data-pns-banner-dot
                aria-label="{{ 'general.slider.name' | t }} {{ forloop.index }}"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </pns-home-banner>

      {%- comment -%} Right: Top Brands {%- endcomment -%}
      <div class="pns-home-banner__brands">
        {%- if section.settings.brands_title != blank -%}
          <div class="pns-home-banner__brands-header color-{{ section.settings.brands_color_scheme }}">
            <h3 class="pns-home-banner__brands-title">{{ section.settings.brands_title | escape }}</h3>
          </div>
        {%- endif -%}
        <ul class="pns-home-banner__brands-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'brand' -%}
              <li class="pns-home-banner__brand-item" {{ block.shopify_attributes }}>
                <a href="{{ block.settings.brand_link }}" class="pns-home-banner__brand-link">
                  {{ block.settings.brand_name | escape }}
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
        {%- if section.settings.cta_label != blank -%}
          <div class="pns-home-banner__cta">
            <a
              href="{{ section.settings.cta_link }}"
              class="pns-home-banner__cta-btn"
              style="--pns-cta-bg: {{ section.settings.cta_bg_color }}; --pns-cta-text: {{ section.settings.cta_text_color }};"
            >
              {{ section.settings.cta_label | escape }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "PNS Home Banner",
  "tag": "section",
  "class": "pns-home-banner-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "rotate_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Rotate every",
      "default": 5
    },
    {
      "type": "header",
      "content": "Top Brands panel"
    },
    {
      "type": "text",
      "id": "brands_title",
      "label": "Brands heading",
      "default": "Top Brands"
    },
    {
      "type": "color_scheme",
      "id": "brands_color_scheme",
      "label": "Brands header color scheme",
      "default": "scheme-3"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "NAILBUYS"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "color",
      "id": "cta_bg_color",
      "label": "CTA button color",
      "default": "#c0392b"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "CTA button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Banner slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand name",
          "default": "Brand"
        },
        {
          "type": "url",
          "id": "brand_link",
          "label": "Brand link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PNS Home Banner",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "brand", "settings": { "brand_name": "CND" } },
        { "type": "brand", "settings": { "brand_name": "OPI" } },
        { "type": "brand", "settings": { "brand_name": "Gelish" } },
        { "type": "brand", "settings": { "brand_name": "Americanails" } },
        { "type": "brand", "settings": { "brand_name": "Cuccio" } },
        { "type": "brand", "settings": { "brand_name": "Voesh" } }
      ]
    }
  ]
}
{% endschema %}
