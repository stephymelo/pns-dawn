{{ 'pns-brand-slider.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pns-brand-slider.js' | asset_url }}" defer="defer"></script>

<div class="pns-brand-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2
        class="pns-brand-section__title {{ section.settings.heading_size }}"
        style="text-align: {{ section.settings.heading_alignment }};"
      >
        {{ section.settings.title | escape }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <pns-brand-slider
        class="pns-brand-slider"
        style="--brand-per-view: {{ section.settings.columns_desktop }};"
        data-interval="{{ section.settings.rotate_speed | times: 1000 }}"
        data-duration="{{ section.settings.transition_speed }}"
      >
        <button type="button" class="slider-button slider-button--prev" aria-label="{{ 'general.slider.previous_slide' | t }}">
          <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
        </button>
        <div class="pns-brand-slider__viewport">
          <div class="pns-brand-slider__track">
            {%- for block in section.blocks -%}
              <div class="pns-brand-slide" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="pns-brand-slide__link">
                {%- endif -%}
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 400
                    | image_tag:
                      loading: 'lazy',
                      widths: '150, 250, 400',
                      class: 'pns-brand-slide__img',
                      alt: block.settings.image.alt | default: block.settings.link | default: 'Brand logo' | escape
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'pns-brand-slide__img placeholder' }}
                {%- endif -%}
                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
        <button type="button" class="slider-button slider-button--next" aria-label="{{ 'general.slider.next_slide' | t }}">
          <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
        </button>
      </pns-brand-slider>
    {%- endif -%}
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "PNS Brand Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Top Brands"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h4", "label": "Small" },
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 7,
      "step": 1,
      "label": "Logos per view (desktop)",
      "default": 5
    },
    {
      "type": "range",
      "id": "rotate_speed",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Rotate every",
      "default": 4
    },
    {
      "type": "range",
      "id": "transition_speed",
      "min": 300,
      "max": 1500,
      "step": 100,
      "unit": "ms",
      "label": "Animation speed",
      "default": 800
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Brand logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PNS Brand Slider",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
