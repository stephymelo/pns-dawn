{{ 'pns-custom.css' | asset_url | stylesheet_tag }}

<div
  class="pns-feature-bar color-{{ section.settings.color_scheme }}"
  style="
    --pns-feature-accent: {{ section.settings.accent_color }};
    --pns-feature-icon-color: {{ section.settings.icon_color }};
    {% if section.settings.background_color != blank %}--pns-feature-bg: {{ section.settings.background_color }};{% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    {% if section.settings.show_bottom_border %}border-bottom: {{ section.settings.bottom_border_width }}px solid {{ section.settings.bottom_border_color }};{% endif %}
  "
>
  <div class="page-width pns-feature-bar__marquee">
    <div class="pns-feature-bar__grid">
      {%- for block in section.blocks -%}
        {%- render 'pns-feature-item', block: block, recolor_icons: section.settings.recolor_icons -%}
      {%- endfor -%}
      {%- comment -%} Duplicate set for the seamless mobile marquee {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- render 'pns-feature-item', block: block, recolor_icons: section.settings.recolor_icons, dup: true -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "PNS Feature Bar",
  "tag": "section",
  "class": "pns-feature-bar-section",
  "enabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "info": "Overrides the color scheme background. Clear to use the color scheme."
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Heading & accent color",
      "default": "#f4b6bc"
    },
    {
      "type": "checkbox",
      "id": "recolor_icons",
      "label": "Recolor icons",
      "info": "Tint uploaded icons to the icon color below. Works best with solid/transparent icons.",
      "default": true
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#f4b6bc"
    },
    {
      "type": "checkbox",
      "id": "show_bottom_border",
      "label": "Show bottom stroke",
      "default": true
    },
    {
      "type": "color",
      "id": "bottom_border_color",
      "label": "Bottom stroke color",
      "default": "#f4b6bc"
    },
    {
      "type": "range",
      "id": "bottom_border_width",
      "min": 0,
      "max": 12,
      "step": 1,
      "unit": "px",
      "label": "Bottom stroke thickness",
      "default": 2
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon",
          "info": "Upload your icon (SVG or PNG). Displays to the left of the text."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Fast Free Shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Subtext",
          "default": "On Most Orders Over $99*"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "PNS Feature Bar",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "heading": "Fast Free Shipping",
            "text": "On Most Orders Over $99*"
          }
        },
        {
          "type": "feature",
          "settings": {
            "heading": "Customer Service",
            "text": "Licensed Nail Techs On Phones & Live Chat"
          }
        },
        {
          "type": "feature",
          "settings": {
            "heading": "Easy Returns",
            "text": "30 Day Return Policy*"
          }
        }
      ]
    }
  ]
}
{% endschema %}
